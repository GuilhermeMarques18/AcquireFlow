PORT=3000
NODE_ENV=development
LOG_LEVEL=info


# REQUIRED: PostgreSQL connection string from Neon Console
# Format: postgresql://user:password@host/database?sslmode=require
# Get this from: https://console.neon.tech → Connection String → Pooled Connection
DB_URL=postgresql://username:password@ep-cool-darkness-123456.us-east-1.aws.neon.tech/neondb?sslmode=require


# REQUIRED: Long random string for signing JWT tokens (minimum 32 characters)
# Generate using: openssl rand -hex 32
JWT_SECRET=your_long_random_jwt_secret_key_min_32_characters

# JWT token expiration time (default: 1h)
JWT_EXPIRES_IN=1h


# Use the actual domain in production (e.g., https://app.example.com)
# Leave empty or set to '*' for development only (not recommended)
CORS_ORIGIN=http://localhost:3001

# REQUIRED: Arcjet API key for rate limiting and bot detection
# Get this from: https://app.arcjet.com → Projects → Create Project
# Keep this secret! Never share or commit it
ARCJET_KEY=ajkey_your_arcjet_api_key_here

# ========================================
# Notes for Different Environments
# ========================================
#
# LOCAL DEVELOPMENT (.env):
#   - NODE_ENV=development
#   - LOG_LEVEL=debug
#   - DB_URL: Connection to Neon Cloud
#   - CORS_ORIGIN: http://localhost:3001
#
# DOCKER DEVELOPMENT (.env.development):
#   - NODE_ENV=development
#   - LOG_LEVEL=debug
#   - DB_URL: Will be overridden to use Neon Local (neon-local:5432)
#   - Used by: docker-compose.dev.yml
#
# DOCKER PRODUCTION (.env.production):
#   - NODE_ENV=production
#   - LOG_LEVEL=info
#   - DB_URL: Connection to Neon Cloud (pooled)
#   - JWT_SECRET: Long, random, and secure
#   - CORS_ORIGIN: Your frontend domain (e.g., https://app.example.com)
#   - Used by: docker-compose.prod.yml
#
# IMPORTANT: Variable names must match exactly:
#   - Use 'DB_URL' (not DATABASE_URL)
#   - See src/config/database.ts for reference
